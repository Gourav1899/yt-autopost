# =============================================
# TubeAutomate v3 — Environment Variables
# Render.com Environment section mein daalo
# =============================================

# Supabase (supabase.com → Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxx   # Service Role Key (NOT anon key)

# Google OAuth (same project jo bot ke liye tha)
GOOGLE_CLIENT_ID=737934707545-xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# OpenRouter (default - users apni key settings mein add kar sakte hain)
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Port (Render ke liye)
PORT=10000
